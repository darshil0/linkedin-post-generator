{
  "entities": {
    "LinkedInPost": {
      "title": "LinkedIn Post",
      "description": "A saved LinkedIn post draft.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the owner." },
        "topic": { "type": "string", "description": "The original user input." },
        "post_type": { "type": "string", "description": "The type of post." },
        "hook": { "type": "string", "description": "The main hook." },
        "post": { "type": "string", "description": "The main content." },
        "cta": { "type": "string", "description": "The call to action." },
        "hashtags": { "type": "array", "items": { "type": "string" }, "description": "List of hashtags." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "post_type", "hook", "post", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "LinkedInPost",
      "description": "User saved posts."
    }
  }
}
